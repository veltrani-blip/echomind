{
  "expo": {
    "name": "echomind",
    "slug": "echomind",
    "scheme": "echomind",

    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "microphonePermission": "Echomind precisa acessar o microfone para sessões de voz."
        }
      ]
    ],

    "android": {
      "package": "com.echomind.app",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.echomind.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Echomind precisa acessar o microfone para sessões de voz.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "web": {
      "bundler": "metro"
    },

    "extra": {
      "eas": {
        "projectId": "dbe96ed3-5891-4b0e-998b-23d1d18b5f3d"
      }
    }
  }
}